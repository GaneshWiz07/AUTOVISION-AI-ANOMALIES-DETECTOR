# Copy this file to .env and fill in real values. Never commit .env itself.

# Supabase project credentials (Project Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT signing secret used for internal token handling - generate a long random value,
# e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Detection tuning
ANOMALY_THRESHOLD=0.7
FRAME_SAMPLING_RATE=5
USE_PRETRAINED_MODELS=True
MODEL_CACHE_DIR=./models

# Video upload limits
MAX_VIDEO_SIZE_MB=100

# Deployment
ENVIRONMENT=development
PORT=12000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://autovision-ai.onrender.com

# Comma-separated emails to provision as system/admin users (user_profiles.is_system_user)
SYSTEM_ADMIN_EMAILS=
